menu "ArgiSense application"

config ARGISENSE_MEASUREMENT_PERIOD_SECONDS
	int "Measurement period in seconds"
	default 60
	range 1 86400
	help
	  Time between sensor measurement windows. The application powers down
	  switched external rails during this interval so the kernel can enter
	  low-power idle states.

config ARGISENSE_PRE_RAIL_ALWAYS_ON
	bool "Keep +3V3_PRE enabled while idle"
	default y
	help
	  Keep the pre-sensor rail powered between measurement windows. This is
	  enabled by default because the selected Dynament Platinum methane sensor
	  is designed for continuous powered operation, and repeated short-interval
	  power cycling is outside the intended use of that product.

config ARGISENSE_PRE_RAIL_SETTLE_MS
	int "Pre-sensor 3V3 rail settle time in milliseconds"
	default 50
	range 0 5000
	help
	  Delay after enabling +3V3_PRE before touching sensors powered from it.

config ARGISENSE_ANALOG_RAIL_SETTLE_MS
	int "Analog rail settle time in milliseconds"
	default 20
	range 0 5000
	help
	  Delay after enabling analog rails before a measurement window begins.

config ARGISENSE_MEASUREMENT_WINDOW_MS
	int "Measurement window in milliseconds"
	default 1000
	range 1 60000
	help
	  Placeholder time that keeps sensor rails enabled for acquisition.
	  Sensor drivers can later replace this window with real sampling logic.

config ARGISENSE_PRESSURE_PS_ACTIVE
	bool "Drive pressure PS signal high during measurements"
	default n
	help
	  Drive PRES_SEN_PS high while the pressure sensor rail is enabled. The
	  selected MS580305BA01-00 / MS5803-05BA pressure sensor uses PS low for SPI
	  and PS high for I2C. The methane + pressure board maps the sensor on spi1,
	  so the default is n to keep PS low during measurements.

config ARGISENSE_DAC_POWER_DURING_MEASUREMENT
	bool "Power DAC rail during measurement windows"
	default y
	help
	  Power the 4-20 mA DAC boost rail during each measurement window so the
	  GP8302 current-loop outputs can be refreshed, then turn it back off in
	  idle to preserve the duty-cycled power model.

config ARGISENSE_DAC_POWER_IDLE
	bool "Keep DAC rail enabled in idle"
	default y
	help
	  Keep the GP8302/current-loop rail powered after the output is refreshed
	  so the 4-20 mA outputs remain active between measurement cycles. Disable
	  this only when the product intentionally duty-cycles the analog output.

config ARGISENSE_DAC_MIN_CURRENT_UA
	int "Normal minimum DAC loop current in microamps"
	default 4000
	range 0 25000
	help
	  Normal low-end current for each 4-20 mA current-loop output channel.

config ARGISENSE_DAC_MAX_CURRENT_UA
	int "Normal maximum DAC loop current in microamps"
	default 20000
	range 0 25000
	help
	  Normal high-end current for each 4-20 mA current-loop output channel.

config ARGISENSE_DAC_FAULT_CURRENT_UA
	int "DAC fault loop current in microamps"
	default 3600
	range 0 25000
	help
	  Current command used when the source sensor value for a DAC channel is
	  invalid. This is the default low-fault value for industrial loops.

config ARGISENSE_METHANE_DAC_RANGE_LOW_PPM
	int "Methane DAC channel low range in ppm"
	default 0
	help
	  Methane concentration mapped to 4 mA on DAC channel 0.

config ARGISENSE_METHANE_DAC_RANGE_HIGH_PPM
	int "Methane DAC channel high range in ppm"
	default 1000000
	help
	  Methane concentration mapped to 20 mA on DAC channel 0. The default
	  matches a 0-100% volume methane Platinum sensor. Use 50000 for a 0-5%
	  volume variant.

config ARGISENSE_METHANE_SENSOR_WARMUP_SECONDS
	int "Dynament methane sensor warm-up time in seconds"
	default 60
	range 0 600
	help
	  Time after first power before the Dynament Platinum digital gas reading is
	  expected to represent the calculated methane value. During warm-up, the
	  digital output may report a fault-style value.

config ARGISENSE_METHANE_SENSOR_READ_PERIOD_MS
	int "Dynament methane live-data polling period in milliseconds"
	default 5000
	range 100 60000
	help
	  Nominal period for the live-data-simple UART request shown in Dynament
	  AN0007.

config ARGISENSE_HUMIDITY_SENSOR_READ_PERIOD_SECONDS
	int "HTU21D humidity read period in seconds"
	default 60
	range 1 86400
	help
	  Nominal period for HTU21D relative humidity and ambient temperature
	  sampling on the methane + pressure board.

config ARGISENSE_PRESSURE_DAC_RANGE_LOW_PA
	int "Pressure DAC channel low range in pascals"
	default 0
	help
	  Pressure value mapped to 4 mA on DAC channel 1.

config ARGISENSE_PRESSURE_DAC_RANGE_HIGH_PA
	int "Pressure DAC channel high range in pascals"
	default 500000
	help
	  Pressure value mapped to 20 mA on DAC channel 1.

menu "RS485 firmware update"

config ARGISENSE_RS485_DFU
	bool "Enable firmware update over RS485 Modbus registers"
	depends on BOOTLOADER_MCUBOOT
	depends on IMG_MANAGER
	depends on FLASH
	depends on FLASH_MAP
	depends on STREAM_FLASH
	default y
	select IMG_ENABLE_IMAGE_CHECK
	select IMG_ERASE_PROGRESSIVELY
	help
	  Add an ArgiSense Modbus register window that receives signed MCUboot
	  images over RS485, writes them to the secondary image slot, verifies
	  the uploaded image hash, and can mark it for a test boot.

config ARGISENSE_RS485_DFU_MAX_CHUNK_BYTES
	int "Maximum RS485 DFU chunk size in bytes"
	depends on ARGISENSE_RS485_DFU
	default 96
	range 16 128
	help
	  Maximum payload bytes accepted by one RS485 DFU write command.
	  The value must be even because each Modbus holding register carries
	  two data bytes. 96 bytes fits comfortably inside the Zephyr Modbus
	  RTU buffer and works well on noisy RS485 links.

config ARGISENSE_RS485_DFU_UNLOCK_KEY
	hex "RS485 DFU service unlock key"
	depends on ARGISENSE_RS485_DFU
	default 0xA65D
	help
	  16-bit service key that must be written to the DFU unlock register
	  before image metadata, payload, or control registers accept writes.
	  Override this in a private production config if RS485 DFU remains
	  enabled in field firmware.

config ARGISENSE_RS485_DFU_UNLOCK_WINDOW_SECONDS
	int "RS485 DFU unlock window in seconds"
	depends on ARGISENSE_RS485_DFU
	default 1800
	range 60 7200
	help
	  Number of seconds that DFU writes remain enabled after a valid unlock
	  key. Choose a value long enough for the slowest supported RS485 baud
	  rate and firmware image size.

endmenu

menu "USB-C device support"

config ARGISENSE_USB_DEVICE
	bool "Initialize ArgiSense USB device-next composite device"
	depends on USB_DEVICE_STACK_NEXT
	depends on USBD_CDC_ACM_CLASS
	default n
	help
	  Initialize the Zephyr USB device-next stack from application code.
	  This is used by the USB update profile so more than one CDC ACM
	  function can be registered on the same USB-C connector.

config ARGISENSE_USB_MANUFACTURER_STRING
	string "USB manufacturer string"
	depends on ARGISENSE_USB_DEVICE
	default "ArgiSense"
	help
	  USB manufacturer string descriptor used by the ArgiSense USB device.

config ARGISENSE_USB_PRODUCT_STRING
	string "USB product string"
	depends on ARGISENSE_USB_DEVICE
	default "ArgiSense USB-C Console and Firmware Update"
	help
	  USB product string descriptor used by the ArgiSense USB device.

config ARGISENSE_USB_VID
	hex "USB vendor ID"
	depends on ARGISENSE_USB_DEVICE
	default 0x2fe3
	help
	  USB vendor ID used by the ArgiSense USB device. Replace this before
	  production if a product-specific VID is assigned.

config ARGISENSE_USB_PID
	hex "USB product ID"
	depends on ARGISENSE_USB_DEVICE
	default 0x0005
	help
	  USB product ID used by the ArgiSense USB update profile.

config ARGISENSE_USB_SELF_POWERED
	bool "Mark USB device as self-powered"
	depends on ARGISENSE_USB_DEVICE
	default n
	help
	  Set the self-powered attribute in the USB configuration descriptor.

config ARGISENSE_USB_MAX_POWER
	int "USB maximum power descriptor value"
	depends on ARGISENSE_USB_DEVICE
	default 125
	range 0 250
	help
	  USB bMaxPower value in 2 mA units. The default advertises 250 mA.

endmenu

endmenu

menu "Zephyr"
source "Kconfig.zephyr"
endmenu
